# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Stable Diffusion - Model (HuggingFace model ID)
SD_MODEL_ID=runwayml/stable-diffusion-inpainting

# Default prompt untuk inpainting (bisa disesuaikan)
SD_PROMPT=person wearing fashionable outfit, high quality, detailed, professional photography, natural lighting

# Negative prompt
SD_NEGATIVE_PROMPT=low quality, blurry, distorted, ugly, bad anatomy, deformed

# Generation parameters
SD_NUM_INFERENCE_STEPS=30
SD_GUIDANCE_SCALE=7.5
SD_STRENGTH=0.85
